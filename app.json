{
  "expo": {
    "name": "BatteryGuard AI",
    "slug": "batteryguard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0A0E21"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.batteryguard.app",
      "bluetoothAlwaysUsageDescription": "BatteryGuard needs Bluetooth to connect to your OBD-II adapter for battery diagnostics."
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0E21",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.batteryguard.app",
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "name": "BatteryGuard AI",
      "shortName": "BatteryGuard",
      "description": "Smart car battery diagnostics via OBD-II Bluetooth",
      "backgroundColor": "#0A0E21",
      "themeColor": "#00D4FF",
      "lang": "en",
      "startUrl": "/",
      "display": "standalone",
      "orientation": "portrait",
      "scope": "/",
      "icons": [
        {
          "src": "./assets/icon.png",
          "sizes": "192x192",
          "type": "image/png"
        },
        {
          "src": "./assets/icon.png",
          "sizes": "512x512",
          "type": "image/png"
        }
      ]
    },
    "plugins": [
      "react-native-ble-plx"
    ]
  }
}
